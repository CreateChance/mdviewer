{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-theme",
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-open",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:default",
      "allow": [{ "path": "**" }]
    }
  ]
}
